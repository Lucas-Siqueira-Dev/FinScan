<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FinScan.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FinScan.App.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Home" Icon="home_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" Route="DashboardPage" />
        </Tab>
        
        <Tab Title="Scan" Icon="camera_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:ScannerPage}" Route="ScannerPage" />
        </Tab>

        <Tab Title="Ajustes" Icon="settings_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>