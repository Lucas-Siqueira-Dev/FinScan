<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinScan.App.Views.DashboardPage"
             BackgroundColor="#F8F9FA">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="25">
            
            <Grid ColumnDefinitions="*, Auto">
                <Label Text="{Binding SaudacaoUsuario}" 
                       FontAttributes="Bold" 
                       FontSize="20" 
                       VerticalOptions="Center" />
                       
                <Button Grid.Column="1" 
                        Text="Seja Premium" 
                        BackgroundColor="#2ECC71" 
                        CornerRadius="20" 
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="40"/>
            </Grid>

            <Frame BackgroundColor="#1565C0" 
                   CornerRadius="15" 
                   HasShadow="True" 
                   Padding="30"
                   BorderColor="Transparent">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label Text="{Binding SaldoDisponivel, StringFormat='R$ {0:N2}'}" 
                           TextColor="White" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center"/>
                    <Label Text="Saldo Disponível" 
                           TextColor="#E3F2FD" 
                           FontSize="16" 
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Últimas Leituras" 
                   FontAttributes="Bold" 
                   FontSize="18" 
                   Margin="0,10,0,0"/>

            <CollectionView ItemsSource="{Binding UltimasLeituras}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#E0E0E0" 
                               CornerRadius="12" 
                               Padding="15" 
                               Margin="0,0,0,15"
                               BorderColor="Transparent">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Image Source="{Binding IconeCategoria}" WidthRequest="25" HeightRequest="25" VerticalOptions="Center"/>
                                
                                <Label Grid.Column="1" 
                                       Text="{Binding NomeServico}" 
                                       FontAttributes="Bold" 
                                       VerticalOptions="Center" 
                                       Margin="15,0,0,0"/>
                                
                                <Label Grid.Column="2" 
                                       Text="{Binding Valor, StringFormat='-{0:N2}'}" 
                                       TextColor="Red" 
                                       FontAttributes="Bold" 
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>