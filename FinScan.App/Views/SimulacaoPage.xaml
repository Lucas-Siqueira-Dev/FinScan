<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinScan.App.ViewModels"
             x:Class="FinScan.App.Views.SimulacaoPage"
             Title="Calculadora de Investimentos"
             BackgroundColor="White">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="18">

            <Label Text="Simulação de Reserva" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,10,0,10" />

            <Label Text="Quanto você tem hoje? (R$)" />
            <Frame Padding="2" CornerRadius="10" BorderColor="LightGray">
                <Entry Keyboard="Numeric" 
                       Text="{Binding ValorInicial}" 
                       Placeholder="Ex: 1000.00" />
            </Frame>

            <Label Text="Aporte Mensal (R$)" />
            <Frame Padding="2" CornerRadius="10" BorderColor="LightGray">
                <Entry Keyboard="Numeric" 
                       Text="{Binding AporteMensal}" 
                       Placeholder="Ex: 200.00" />
            </Frame>

            <Label Text="Por quanto tempo? (Meses)" />
            <Frame Padding="2" CornerRadius="10" BorderColor="LightGray">
                <Entry Keyboard="Numeric" 
                       Text="{Binding TempoMeses}" 
                       Placeholder="Ex: 12" />
            </Frame>

            <Button Text="Calcular Rendimento" 
                    Command="{Binding CalcularSimulacaoCommand}" 
                    BackgroundColor="#2196F3" 
                    TextColor="White" 
                    HeightRequest="50" 
                    CornerRadius="25" 
                    Margin="0,15,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               IsVisible="{Binding IsBusy}" 
                               Color="#2196F3" 
                               HorizontalOptions="Center" />

            <VerticalStackLayout Margin="0,20,0,0" 
                                 HorizontalOptions="Center">
                <Label Text="Valor Final Estimado" 
                       FontSize="16" 
                       HorizontalOptions="Center" />
                       
                <Label Text="{Binding ResultadoFinal, StringFormat='R$ {0:N2}'}" 
                       FontSize="36" 
                       TextColor="#2E7D32" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>